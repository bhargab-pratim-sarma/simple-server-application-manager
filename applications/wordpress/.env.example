# ── TRAEFIK ROUTING ──────────────────────────
APP_DOMAIN=yourdomain.com
ROUTER_NAME=your_unique_router_name

# ── WORDPRESS SETTINGS ─────────────────────────
WP_IMAGE=wordpress:latest
WP_CONTAINER_NAME=wordpress_app
WP_PORT=80

# ── DATABASE SETTINGS ──────────────────────────
DB_IMAGE=mariadb:10.11
DB_CONTAINER_NAME=wordpress_db
DB_NAME=wordpress_db
DB_USER=wordpress_user
DB_PASSWORD=your_strong_password
DB_ROOT_PASSWORD=your_strong_root_password

# ── NETWORK SETTINGS ───────────────────────────
INTERNAL_NETWORK_NAME=wp_internal
