# ============================================
# App Environment Variables
# ============================================
# Copy this file for each new app you want to deploy.
# Update the values below, then run:
#   docker compose up -d
# ============================================

# ── TRAEFIK ROUTING ──────────────────────────
# The domain for this app (must point to your server IP in DNS)
APP_DOMAIN=yourapp.yourdomain.com

# A unique name for this app's Traefik router (no spaces, lowercase)
# IMPORTANT: This must be different for every app!
# Examples: blog, portfolio, api, dashboard
ROUTER_NAME=yourapp

# ── APP SETTINGS ─────────────────────────────
# The Docker image to use
APP_IMAGE=ghost:latest

# The port your app listens on INSIDE the container
# Common ports: 80 (nginx), 3000 (node), 8080 (java), 2368 (ghost)
APP_PORT=2368

# Container name (for easy identification in docker ps)
CONTAINER_NAME=yourapp
